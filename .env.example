# ──────────────────────────────────────────────────────────────────────────────
# JARVIS — environment variables
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────────────────────

# Your OpenAI API key (required when using OpenAI models).
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ─── Optional settings ────────────────────────────────────────────────────────

# Model to use. Defaults to gpt-4o-mini if not set.
# Examples: gpt-4o, gpt-4o-mini, gpt-3.5-turbo
# JARVIS_MODEL=gpt-4o-mini

# Custom API base URL — use this to point JARVIS at a local Ollama instance
# or any other OpenAI-compatible endpoint instead of api.openai.com.
#
# Example (Ollama running locally):
#   OPENAI_BASE_URL=http://localhost:11434/v1
#   JARVIS_MODEL=llama3
#   OPENAI_API_KEY=ollama      # Ollama does not require a real key
# OPENAI_BASE_URL=
